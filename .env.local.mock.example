APP_NAME=PUI Adapter Service
APP_ENV=local
PUBLIC_BASE_URL=
DATABASE_URL=sqlite+pysqlite:///./pui_adapter.db
CORE_BACKEND=simulated
CORE_SIMULATION_FILE=
JWT_SECRET_KEY=local-dev-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
PUI_INBOUND_USER=PUI
PUI_INBOUND_PASSWORD=LocalPassword123!
PUI_OUTBOUND_BASE_URL=http://localhost:8010
PUI_OUTBOUND_INSTITUCION_ID=RFC123456ABC
PUI_OUTBOUND_CLAVE=ChangeMePassword1!
PUI_OUTBOUND_ENABLED=true
PUI_REQUEST_TIMEOUT_SECONDS=10
SCHEDULER_ENABLED=true
SCHEDULER_PHASE3_MINUTES=60
RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_REQUESTS=20
API_RATE_LIMIT_REQUESTS=120
