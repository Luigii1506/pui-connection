APP_NAME=PUI Adapter Service
APP_ENV=production
PUBLIC_BASE_URL=https://pui.empresa.com
DATABASE_URL=postgresql+psycopg://pui_user:change_me@db-host:5432/pui_adapter
CORE_BACKEND=simulated
CORE_SIMULATION_FILE=
JWT_SECRET_KEY=replace-with-company-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
PUI_INBOUND_USER=PUI
PUI_INBOUND_PASSWORD=replace-with-registered-webhook-password
PUI_OUTBOUND_BASE_URL=https://plataformadebusqueda.gob.mx/api/2_3_0
PUI_OUTBOUND_INSTITUCION_ID=RFC_REAL_EMPRESA
PUI_OUTBOUND_CLAVE=replace-with-pui-production-credential
PUI_OUTBOUND_ENABLED=true
PUI_REQUEST_TIMEOUT_SECONDS=10
SCHEDULER_ENABLED=true
SCHEDULER_PHASE3_MINUTES=60
